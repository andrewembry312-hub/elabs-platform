# E-Labs Platform — Environment Configuration
# Copy this file to .env and fill in values before starting.
# NEVER commit .env to version control.

# ── JWT Authentication ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ELABS_JWT_SECRET=CHANGE_ME_use_32_plus_char_random_secret

# Set to "1" in production to enforce Bearer JWT on all API endpoints.
# Leave "0" for local development (no login required).
ELABS_REQUIRE_AUTH=0

# ── OpenClaw Gateway ────────────────────────────────────────────────────────
# Token clients must send in Authorization: Bearer <token> to reach gateway.elabs.com
OPENCLAW_BEARER_TOKEN=CHANGE_ME_use_strong_random_token

# OpenClaw gateway URL (default: local)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# ── Server Ports ────────────────────────────────────────────────────────────
# Backend API (uvicorn)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001

# Waitress (consulting site, Caddy reverse_proxies here)
WAITRESS_HOST=127.0.0.1
WAITRESS_PORT=8080
WAITRESS_THREADS=8

# ── ComfyUI ─────────────────────────────────────────────────────────────────
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_DEFAULT_MODEL=Wan 2.1

# ── CORS (production) ───────────────────────────────────────────────────────
# Comma-separated list of extra allowed origins beyond the built-in defaults.
# Built-in defaults already include copilot.elabsai.com and github.io.
# Add any additional subdomains here.
# ELABS_EXTRA_CORS=https://app.yourdomain.com

# ── Cloudflare Tunnel ───────────────────────────────────────────────────────
# After running: cloudflared tunnel create elabs-prod
# The tunnel UUID is printed and stored in ~/.cloudflared/<UUID>.json
# Use tunnel/install-tunnel.ps1 to automate the full setup.
# CLOUDFLARE_TUNNEL_UUID=PASTE_UUID_HERE

# ── Production domain ───────────────────────────────────────────────────────
PUBLIC_DOMAIN=copilot.elabsai.com

# ── Stripe Billing ─────────────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com
# Test keys start with sk_test_ / pk_test_ — swap for sk_live_ in production
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Price IDs — created in Stripe Test Sandbox on 2026-04-30
# Switch to live mode and recreate products when going to production (sk_live_)
STRIPE_COPILOT_PRO_PRICE=price_1TS2wsAghjncpWc6r3da80fv      # $19/month
STRIPE_COPILOT_TEAM_PRICE=price_1TS2yDAghjncpWc69ZQouybo     # $49/month
STRIPE_MACHINE_STARTER_PRICE=price_1TS2ykAghjncpWc6WA4ec5Rp  # $29/month
STRIPE_MACHINE_PRO_PRICE=price_1TS2zYAghjncpWc6OrM0Fpcr      # $79/month
STRIPE_CONTENT_STUDIO_BASIC_PRICE=price_1TSPEJAghjncpWc62Ve0sPyG   # $49/month
STRIPE_CONTENT_STUDIO_PRO_PRICE=price_1TSPGXAghjncpWc6ZX4xzld3    # $149/month
