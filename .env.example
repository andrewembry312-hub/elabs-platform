# E-Labs Platform — Environment Configuration
# Copy this file to .env and fill in values before starting.
# NEVER commit .env to version control.

# ── JWT Authentication ──────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
ELABS_JWT_SECRET=CHANGE_ME_use_32_plus_char_random_secret

# Set to "1" in production to enforce Bearer JWT on all API endpoints.
# Leave "0" for local development (no login required).
ELABS_REQUIRE_AUTH=0

# ── OpenClaw Gateway ────────────────────────────────────────────────────────
# Token clients must send in Authorization: Bearer <token> to reach gateway.elabs.com
OPENCLAW_BEARER_TOKEN=CHANGE_ME_use_strong_random_token

# OpenClaw gateway URL (default: local)
OPENCLAW_GATEWAY_URL=http://127.0.0.1:18789

# ── Server Ports ────────────────────────────────────────────────────────────
# Backend API (uvicorn)
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8001

# Waitress (consulting site, Caddy reverse_proxies here)
WAITRESS_HOST=127.0.0.1
WAITRESS_PORT=8080
WAITRESS_THREADS=8

# ── ComfyUI ─────────────────────────────────────────────────────────────────
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_DEFAULT_MODEL=Wan 2.1
